int maxArea(int* height, int heightSize) {
    int maxArea = 0;
    int k = 0;
    int i =  heightSize-1;
    while(k<i){
        int area = (i-k)*(height[i]>height[k] ? height[k] : height[i]);
        if(area > maxArea)
        {
            maxArea = area;
        }
        if(height[k] < height[i])
        {
            k++;
        }
        else
        {
            i--;
        }
    }
    return maxArea;
}
