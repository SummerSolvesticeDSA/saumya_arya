void sortColors(int* nums, int numsSize) {
    int red = 0;
    int white = 0;
    int blue = 0;
    for(int i = 0; i<numsSize; i++)
    {
        if(nums[i]==0)
        {
            red++;
        }
        else if(nums[i]==1)
        {
            white++;
        }
        else
        {
            blue++;
        }
    }

    int i = 0;

    while(red--)
        nums[i++] = 0;

    while(white--)
        nums[i++] = 1;

    while(blue--)
        nums[i++] = 2;
}
